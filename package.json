{
  "name": "@arbitro/client",
  "version": "0.2.0",
  "description": "Official TypeScript client for the Arbitro message broker",
  "keywords": [
    "arbitro",
    "broker",
    "message-broker",
    "pubsub",
    "queue",
    "messaging",
    "client",
    "typescript",
    "tcp"
  ],
  "homepage": "https://github.com/arbitro-io/arbitro-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arbitro-io/arbitro-ts.git"
  },
  "bugs": {
    "url": "https://github.com/arbitro-io/arbitro-ts/issues"
  },
  "author": "zenozaga and Arbitro contributors",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "bench": "tsx benches/throughput.ts",
    "bench:limit": "tsx benches/limits.ts",
    "bench:chaos": "tsx benches/chaos.ts",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@types/node": ">=18",
    "pino": ">=8",
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "pino": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "msgpackr": "^1.10.0"
  },
  "engines": {
    "node": ">=20"
  }
}
